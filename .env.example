# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored; `.env.example` is committed as a template.

# FRED (St. Louis Fed) — free at https://fred.stlouisfed.org/docs/api/api_key.html
# Used by: data/fetchers.py, data/economic.py
FRED_API_KEY=your_fred_api_key_here

# e-Stat (Portal Site of Official Statistics of Japan) — free at
# https://www.e-stat.go.jp/api/  (up to 3 application IDs per account)
# Used by: data/economic.py (Japan indicators once wired)
ESTAT_API_KEY=your_estat_application_id_here
